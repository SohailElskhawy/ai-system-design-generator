# Google Gemini API Settings (Optional for Server)
# ===============================================
# users to use their own Gemini API keys in the browser settings/navbar (BYOK mode).
#
# Only set this if you want to provide a shared default API key for your deployment.
# GOOGLE_API_KEY=your_shared_google_gemini_api_key_here

# Optional: Targeted model for generation (falls back to gemini-2.5-flash / gemini-2.0-flash series if not provided)
GOOGLE_MODEL=gemini-3.5-flash
